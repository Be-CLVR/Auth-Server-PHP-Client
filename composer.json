{
    "name": "be-clvr/auth-server-php-client",
    "description": "Be CLVR REST API client for the Auth Server SaaS",
    "type": "library",
    "authors": [
        {
          "name": "Wouter de Berg",
          "email": "wouter@brendan-mackenzie.com"
        },
        {
            "name": "Terence Nelson",
            "email": "terence@brendan-mackenzie.com"
        }
      ],
    "require": {
        "php": "^7.3|^8.1|^8.2|^8.3|^8.4|^8.5",
        "ext-curl": "*",
        "ext-json": "*",
        "firebase/php-jwt": "^6.4",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0"
    },
    "license": "MIT",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
          "BeCLVR\\AuthServerClient\\": "src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BeCLVR\\AuthServerClient\\AuthServerServiceProvider"
            ],
            "aliases": {
                "AuthServer": "BeCLVR\\AuthServerClient\\Facades\\AuthServer"
            }
        }
    }
}
